# Asik Dev provider secrets and defaults
# Copied to ~/.config/asik-dev/providers.env with mode 600.
# Use `asik-dev secrets`; do not commit the populated file.

# --- AI / LLM providers ---
OPENAI_API_KEY=''
ANTHROPIC_API_KEY=''
ZAI_API_KEY=''
XAI_API_KEY=''
GEMINI_API_KEY=''         # Used by Gemini CLI and Google Antigravity (agy)
OPENROUTER_API_KEY=''
CURSOR_API_KEY=''
OLLAMA_API_KEY=''
GITHUB_COPILOT_TOKEN=''   # Used by GitHub Copilot CLI (gh copilot)

# --- Search & retrieval ---
BRAVE_API_KEY=''
TAVILY_API_KEY=''

# --- Additional LLM providers ---
GROQ_API_KEY=''
DEEPSEEK_API_KEY=''
TOGETHER_API_KEY=''
MISTRAL_API_KEY=''
CEREBRAS_API_KEY=''

# --- Azure OpenAI ---
AZURE_OPENAI_API_KEY=''
AZURE_OPENAI_ENDPOINT=''
AZURE_OPENAI_DEPLOYMENT=''

# --- AWS ---
AWS_BEARER_TOKEN_BEDROCK=''
AWS_PROFILE=''
AWS_REGION='us-west-2'

# --- Google Cloud ---
GOOGLE_CLOUD_PROJECT=''
VERTEX_LOCATION='global'

# --- Infrastructure ---
PULUMI_ACCESS_TOKEN=''    # Pulumi Cloud access token (optional; local backends work without it)

# --- Dotfiles sync ---
ASIK_DEV_DOTFILES_REPO='' # Git URL for `asik-dev sync`, e.g. https://github.com/you/dotfiles

# --- Optional model and camera overrides ---
# Run `ollama list` before choosing a cloud model because availability changes.
OLLAMA_MODEL='gpt-oss:120b'
OPENROUTER_VISION_MODEL='openrouter/free'
RTSP_URL=''
AIDER_XAI_MODEL='grok-4.5'
AIDER_OPENROUTER_MODEL='anthropic/claude-sonnet-4.5'
