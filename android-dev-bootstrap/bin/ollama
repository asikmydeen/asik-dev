#!/usr/bin/env python3
# Cloud-only Ollama-compatible CLI for direct ollama.com API access.

from __future__ import annotations

import json
import os
import subprocess
import sys
import time
import urllib.error
import urllib.request
from typing import Any, Iterable

VERSION = "1.2.2"

# ---------------------------------------------------------------------------
# improvement #10: configurable retry and timeout settings
# ---------------------------------------------------------------------------
_REQUEST_TIMEOUT = int(os.getenv("OLLAMA_REQUEST_TIMEOUT", "300"))
_STREAM_TIMEOUT = int(os.getenv("OLLAMA_STREAM_TIMEOUT", "1800"))
_MAX_RETRIES = int(os.getenv("OLLAMA_MAX_RETRIES", "3"))
_RETRY_INITIAL_DELAY = float(os.getenv("OLLAMA_RETRY_DELAY", "2.0"))

# HTTP status codes that are worth retrying (transient errors).
_RETRYABLE_HTTP_CODES = {429, 500, 502, 503, 504}


def load_provider_environment() -> None:
    path = os.getenv(
        "ASIK_DEV_PROVIDERS",
        os.path.expanduser("~/.config/asik-dev/providers.env"),
    )
    if not os.path.isfile(path):
        return
    completed = subprocess.run(
        ["bash", "-c", 'set -a; source "$1"; env -0', "asik-dev", path],
        check=False,
        capture_output=True,
    )
    if completed.returncode != 0:
        return
    for entry in completed.stdout.split(b"\0"):
        if b"=" not in entry:
            continue
        key, value = entry.split(b"=", 1)
        os.environ.setdefault(key.decode(errors="ignore"), value.decode(errors="ignore"))


load_provider_environment()
BASE_URL = os.getenv("OLLAMA_HOST", "https://ollama.com").rstrip("/")
API_KEY = os.getenv("OLLAMA_API_KEY", "")
DEFAULT_MODEL = os.getenv("OLLAMA_MODEL", "gpt-oss:120b")


def headers() -> dict[str, str]:
    result = {
        "Content-Type": "application/json",
        "User-Agent": f"asik-dev-ollama/{VERSION}",
    }
    if API_KEY:
        result["Authorization"] = f"Bearer {API_KEY}"
    return result


def _url_error_hint(exc: urllib.error.URLError) -> str:
    """
    improvement #10: produce an actionable hint for URLError instead of
    surfacing the raw socket/SSL reason string.
    """
    reason = str(exc.reason)
    hints: list[str] = []
    if "name or service not known" in reason.lower() or "nodename nor servname" in reason.lower():
        hints.append("DNS resolution failed — check your internet connection.")
    elif "timed out" in reason.lower():
        hints.append(
            f"Connection timed out after {_REQUEST_TIMEOUT}s. "
            "You can raise this with: export OLLAMA_REQUEST_TIMEOUT=600"
        )
    elif "ssl" in reason.lower() or "certificate" in reason.lower():
        hints.append("TLS/SSL error — your system certificates may be out of date.")
    else:
        hints.append("Check your network connection and firewall settings.")

    hints.append(
        f"If OLLAMA_HOST is set incorrectly, verify it points to the right endpoint "
        f"(currently: {BASE_URL})."
    )
    hints.append("To change the API base, run: asik-dev secrets set OLLAMA_HOST")
    return "\n".join(hints)


def _request_with_retry(
    req: urllib.request.Request,
    timeout: int,
    stream: bool = False,
) -> Any:
    """
    improvement #10: retry transient HTTP errors and URLErrors with
    exponential backoff before raising to the caller.
    """
    delay = _RETRY_INITIAL_DELAY
    for attempt in range(1, _MAX_RETRIES + 2):  # +2 so the last attempt still runs
        try:
            response = urllib.request.urlopen(req, timeout=timeout)
            if stream:
                return response  # caller handles the streaming body
            with response:
                body = response.read()
                return json.loads(body) if body[:1] in (b"{", b"[") else body.decode()

        except urllib.error.HTTPError as exc:
            detail = exc.read().decode(errors="replace")
            hint = ""
            if exc.code == 410:
                hint = (
                    "\nHint: this model was retired. "
                    "Run `ollama list` and use an exact current model name."
                )
            if exc.code in _RETRYABLE_HTTP_CODES and attempt <= _MAX_RETRIES:
                print(
                    f"[warn] HTTP {exc.code} — retrying in {delay:.0f}s "
                    f"(attempt {attempt}/{_MAX_RETRIES})...",
                    file=sys.stderr,
                )
                time.sleep(delay)
                delay *= 2
                continue
            raise RuntimeError(
                f"Ollama API returned HTTP {exc.code}: {detail}{hint}"
            ) from exc

        except urllib.error.URLError as exc:
            if attempt <= _MAX_RETRIES:
                print(
                    f"[warn] Network error — retrying in {delay:.0f}s "
                    f"(attempt {attempt}/{_MAX_RETRIES}): {exc.reason}",
                    file=sys.stderr,
                )
                time.sleep(delay)
                delay *= 2
                continue
            hint = _url_error_hint(exc)
            raise RuntimeError(
                f"Unable to reach {BASE_URL}: {exc.reason}\n{hint}"
            ) from exc

    # Should never be reached, but satisfies type checkers.
    raise RuntimeError("Exceeded maximum retry attempts.")


def request_json(method: str, path: str, payload: dict[str, Any] | None = None) -> Any:
    data = json.dumps(payload).encode() if payload is not None else None
    req = urllib.request.Request(
        f"{BASE_URL}{path}", data=data, headers=headers(), method=method
    )
    return _request_with_retry(req, timeout=_REQUEST_TIMEOUT)


def stream_chat(model: str, messages: list[dict[str, str]]) -> str:
    payload = {"model": model, "messages": messages, "stream": True}
    req = urllib.request.Request(
        f"{BASE_URL}/api/chat",
        data=json.dumps(payload).encode(),
        headers=headers(),
        method="POST",
    )
    full: list[str] = []
    response = _request_with_retry(req, timeout=_STREAM_TIMEOUT, stream=True)
    try:
        with response:
            for raw_line in response:
                line = raw_line.decode(errors="replace").strip()
                if not line:
                    continue
                part = json.loads(line)
                text = part.get("message", {}).get("content", "")
                if text:
                    print(text, end="", flush=True)
                    full.append(text)
                if part.get("done"):
                    break
    finally:
        print()
    return "".join(full)


def require_key() -> None:
    if not API_KEY:
        raise RuntimeError("OLLAMA_API_KEY is not set. Run: asik-dev secrets set OLLAMA_API_KEY")


def iter_models(payload: Any) -> Iterable[dict[str, Any]]:
    if isinstance(payload, dict) and isinstance(payload.get("models"), list):
        yield from (m for m in payload["models"] if isinstance(m, dict))


def cmd_list() -> None:
    require_key()
    payload = request_json("GET", "/api/tags")
    print(f"{'NAME':48} {'SIZE':>12}  MODIFIED")
    for model in iter_models(payload):
        name = str(model.get("name") or model.get("model") or "")
        print(f"{name:48} {str(model.get('size', '')):>12}  {model.get('modified_at', '')}")


def cmd_run(args: list[str]) -> None:
    require_key()
    model = args[0] if args else DEFAULT_MODEL
    prompt = " ".join(args[1:]).strip() if len(args) > 1 else ""
    messages: list[dict[str, str]] = []
    if prompt:
        messages.append({"role": "user", "content": prompt})
        stream_chat(model, messages)
        return

    print(f"Cloud model: {model}. Type /bye to exit.")
    while True:
        try:
            prompt = input(">>> ").strip()
        except (EOFError, KeyboardInterrupt):
            print()
            return
        if not prompt:
            continue
        if prompt in {"/bye", "/exit", "bye", "exit"}:
            return
        messages.append({"role": "user", "content": prompt})
        reply = stream_chat(model, messages)
        messages.append({"role": "assistant", "content": reply})


def help_text() -> str:
    return f"""Cloud-only Ollama API wrapper {VERSION}

Usage:
  ollama list
  ollama run [MODEL] [PROMPT...]
  ollama signin
  ollama version
  ollama help

Defaults:
  host:  {BASE_URL}
  model: {DEFAULT_MODEL}

Environment overrides:
  OLLAMA_HOST              API base URL (default: https://ollama.com)
  OLLAMA_MODEL             Default model name
  OLLAMA_REQUEST_TIMEOUT   Seconds before a non-streaming request times out (default: 300)
  OLLAMA_STREAM_TIMEOUT    Seconds before a streaming request times out (default: 1800)
  OLLAMA_MAX_RETRIES       Number of retries for transient errors (default: 3)
  OLLAMA_RETRY_DELAY       Initial backoff delay in seconds (default: 2)

Run `ollama list` before selecting a model because cloud models can be retired.
This wrapper never starts a local daemon or downloads local model weights.
"""


def main() -> int:
    args = sys.argv[1:]
    command = args.pop(0) if args else "help"
    try:
        if command in {"help", "--help", "-h"}:
            print(help_text())
        elif command in {"version", "--version", "-v"}:
            print(f"asik-dev ollama-cloud {VERSION}")
        elif command in {"list", "ls"}:
            cmd_list()
        elif command == "run":
            cmd_run(args)
        elif command == "signin":
            print("Create an API key at ollama.com, then run:")
            print("  asik-dev secrets set OLLAMA_API_KEY")
        elif command in {"pull", "serve", "create", "rm", "stop"}:
            print(f"`ollama {command}` is disabled in this cloud-only wrapper.", file=sys.stderr)
            return 2
        else:
            print(f"Unknown command: {command}\n\n{help_text()}", file=sys.stderr)
            return 2
    except (RuntimeError, json.JSONDecodeError) as exc:
        print(f"error: {exc}", file=sys.stderr)
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
